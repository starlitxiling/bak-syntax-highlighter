{
  "name": "bak-syntax-highlighter",
  "displayName": "Backup File Highlighter (.bak)",
  "description": "Auto-detects .py.bak, .cpp.bak, and other backup files and applies the correct syntax highlighting in VS Code.",
  "version": "0.0.2",
  "publisher": "starlitxiling",
  "icon": "images/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/starlitxiling/bak-syntax-highlighter"
  },
  "engines": {
    "vscode": "^1.50.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:plaintext",
    "onFileSystem:file",
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [],
    "commands": [
      {
        "command": "bakSyntaxHighlighter.openOriginalFile",
        "title": "Open Original File from Backup",
        "category": "Backup File Highlighter"
      }
    ],
    "configuration": {
      "title": "Backup File Highlighter",
      "properties": {
        "bakSyntaxHighlighter.navigation.showBakWarning": {
          "type": "boolean",
          "default": true,
          "description": "Show a warning when a .bak file becomes active so you know code navigation may have landed in a backup file."
        },
        "bakSyntaxHighlighter.navigation.autoOpenOriginal": {
          "type": "boolean",
          "default": false,
          "description": "Automatically switch from a .bak file to its original file when the original path exists."
        }
      }
    }
  },
  "categories": [
    "Other",
    "Languages"
  ],
  "keywords": [
    "syntax",
    "highlight",
    "language mode",
    "bak",
    "backup",
    "auto detect",
    "python",
    "cpp",
    "file extension"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.50.0",
    "@types/node": "^14.14.6",
    "typescript": "^4.0.3",
    "eslint": "^7.10.0",
    "vscode-test": "^1.4.0"
  }
}
